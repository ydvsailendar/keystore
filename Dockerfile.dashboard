FROM python:3.10-slim
RUN apt-get update && \
    apt-get install -y sqlite3 libsqlite3-dev gcc && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY dashboard.py .
COPY init_db.py .
RUN pip install fastapi uvicorn pydantic
RUN python init_db.py
CMD ["uvicorn", "dashboard:app", "--host", "0.0.0.0", "--port", "8000"]
